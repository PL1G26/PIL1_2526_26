# ============================================================
# IFRI_MentorLink — Environment Variables (Example)
# Projet intégrateur PIL1 2025-2026
#
# COPIER DANS .env ET METTEZ-Y VOS PROPRES DONNÉES
# NE JAMAIS COMMIT .env VERS GIT (ajouter à .gitignore)
# ============================================================

# ──── DATABASE CONNECTION (Supabase PostgreSQL) ────────────
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# Supabase settings (optional, used for Supabase client / realtime features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ──── JWT AUTHENTICATION ───────────────────────────────────
# Secret key for signing JWT tokens (use a strong random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_super_secret_jwt_key_change_this_in_production

# JWT token expiration in hours
TOKEN_EXPIRE_HOURS=24

# Algorithm for JWT (HS256 is standard)
ALGORITHM=HS256

# ──── CORS & API SETTINGS ──────────────────────────────────
# Frontend origin(s) allowed to call this API
# Comma-separated for multiple origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API environment (development, staging, production)
ENV=development

# ──── SERVER CONFIGURATION ─────────────────────────────────
# Host and port for uvicorn
HOST=0.0.0.0
PORT=8000

# ──── LOGGING ──────────────────────────────────────────────
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO